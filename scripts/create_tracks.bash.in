## This script creates the data_tracks files; it uses as arguments
## - a bed file
## - a name as an appendix for further analysis

if [ $# -ne 3 ]; then
	echo "Usage: create_tracks.bash <bed_file> <fasta_file> <name>"
	exit 1
fi
if ! [[ -f "$1" ]]; then
     echo "!!!!!   bed file not found!."
     exit 1
   fi

if ! [[ -f "$2" ]]; then
     echo "!!!!!   fasta file not found!."
     exit 1
   fi

mkdir -p data_tracks

echo "-----Calculating coverage tracks for each exon-----"

## --- Low-memory coverage via bedtools streaming (-sorted) --------------------
## bedtools >= 2.24 computes 'coverage' for -a and loads the -b file into RAM,
## which OOMs on large BAMs. We stream both inputs with -sorted instead: build a
## genome file in the BAMs' coordinate-sort order and sort the small region file
## to match. Output is byte-identical to the default algorithm. (The lighter
## P_sites_all / Centered_RNA calls stay on the default algorithm.)
rt_gen="rt_genome_$3.txt"
@SAMTOOLS@ view -H RIBO_best.bam | awk -F'\t' '/^@SQ/{c="";l=""; for(i=1;i<=NF;i++){if($i~/^SN:/)c=substr($i,4); if($i~/^LN:/)l=substr($i,4)} if(c!="")print c"\t"l}' > "$rt_gen"
rt_reg="rt_region_sorted_$3.bed"
@BEDTOOLS@ sort -g "$rt_gen" -i "$1" > "$rt_reg"

@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -split -a "$rt_reg" -b RIBO_unique.bam | sort -k1,1 -k2,2g | sed 's/_//g' | awk '{ print $1 "_" $2 "_" $3 "_" $4 "_" $5"\t" $6 "\t" $7 "\t" $8 "\t" $9 "\t" $10}' > RIBO_unique_counts"_$3"

@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -split -a "$rt_reg" -b RNA_unique.bam | sort -k1,1 -k2,2g |  sed 's/_//g' | awk '{ print $1 "_" $2 "_" $3 "_" $4 "_" $5"\t" $6 "\t" $7 "\t" $8 "\t" $9 "\t" $10}' > RNA_unique_counts"_$3"

@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -split -a "$rt_reg" -b RIBO_best.bam | sort -k1,1 -k2,2g | sed 's/_//g' |  awk '{ print $1 "_" $2 "_" $3 "_" $4 "_" $5"\t" $6 "\t" $7 "\t" $8 "\t" $9 "\t" $10}' > RIBO_best_counts"_$3"

@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -split -a "$rt_reg" -b RNA_best.bam | sort -k1,1 -k2,2g | sed 's/_//g' | awk '{ print $1 "_" $2 "_" $3 "_" $4 "_" $5"\t" $6 "\t" $7 "\t" $8 "\t" $9 "\t" $10}' > RNA_best_counts"_$3"


@BEDTOOLS@ coverage -s -d -a $1 -b P_sites_all |  awk '{ print $1 ";" $2 ";" $3 ";" $4 ";" $5";" $6 "\t" "_" $8}' | awk -F"\t" '{if(a[$1])a[$1]=a[$1]" "$NF; else a[$1]=$NF}END{for (i in a)print i "\t" a[i]}'| sed 's/_//g' | sed 's/;/\t/g' | sort -k1,1 -k4,4 -k2,2g > data_tracks/P_sites_all_tracks"_$3"


@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -d -split -a "$rt_reg" -b RIBO_best.bam | awk '{ print $1 ";" $2 ";" $3 ";" $4 ";" $5";" $6 "\t" "_" $8}' | awk -F"\t" '{if(a[$1])a[$1]=a[$1]" "$NF; else a[$1]=$NF}END{for (i in a)print i "\t" a[i]}'| sed 's/_//g' | sed 's/;/\t/g' | sort -k1,1 -k4,4 -k2,2g > data_tracks/RIBO_tracks"_$3"

@BEDTOOLS@ coverage -sorted -g "$rt_gen" -s -d -split -a "$rt_reg" -b RNA_best.bam | awk '{ print $1 ";" $2 ";" $3 ";" $4 ";" $5";" $6 "\t" "_" $8}' | awk -F"\t" '{if(a[$1])a[$1]=a[$1]" "$NF; else a[$1]=$NF}END{for (i in a)print i "\t" a[i]}'| sed 's/_//g' | sed 's/;/\t/g' | sort -k1,1 -k4,4 -k2,2g > data_tracks/RNA_tracks"_$3"

@BEDTOOLS@ coverage -s -d -a $1 -b Centered_RNA |  awk '{ print $1 ";" $2 ";" $3 ";" $4 ";" $5";" $6 "\t" "_" $8}' | awk -F"\t" '{if(a[$1])a[$1]=a[$1]" "$NF; else a[$1]=$NF}END{for (i in a)print i "\t" a[i]}'| sed 's/_//g' | sed 's/;/\t/g' | sort -k1,1 -k4,4 -k2,2g > data_tracks/Centered_RNA_tracks"_$3"

rm -f "$rt_gen" "$rt_reg"

echo "-----Merging tracks together-----"


cat data_tracks/P_sites_all_tracks"_$3" data_tracks/RIBO_tracks"_$3" data_tracks/RNA_tracks"_$3" data_tracks/Centered_RNA_tracks"_$3" $2 | tr '\t' '_' | sed 's/_/\t/6' | awk -F"\t" '{a[$1]=a[$1]"\n" $1 "\t" $2}END{for (i in a)print i "\t" a[i];}' | awk -F"\t" '{if($2>=0)print $0}' | sed 's/_/ /5' | sed 's/\t/ /1' > data_tracks/Psit_Ribo_Rna_Cent_tracks"_$3"

cut -f 1 data_tracks/Psit_Ribo_Rna_Cent_tracks"_$3" -d" " > data_tracks/index_tracks"_$3"



