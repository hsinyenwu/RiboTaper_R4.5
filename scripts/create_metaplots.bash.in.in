## This script creates aggregate plots around start-stop codons, it
## uses as arguments
## - a bam file
## - a bed file for start-stop positions
##   (e.g. the one produced by the create_annotation.bash script)
## - a name as an appendix for further analysis

# This is a placeholder to be replaced at build time
#:MAKE

if [ $# -ne 3 ]; then
	echo "Usage: create_metaplots.bash <ribo.bam> <bedfile> <name>"
	exit 1
fi
if ! [[ -f "$1" ]]; then
     echo "!!!!!   ribo.bam file not found!."
     exit 1
   fi
if ! [[ -f "$2" ]]; then
     echo "!!!!!   start_stop bed file not found!."
     exit 1
   fi

echo "Downsampling to 10%..."

@SAMTOOLS@ view -b -s 1.1 $1 > sample_to_metapl.bam

echo "Intersecting alignments with start/stop sites ..."

# Stream the reads through `window` (reads on -a, the small start/stop file on -b) so
# bedtools only loads the tiny -b file into RAM instead of the whole read set. Output is
# identical; the read (12 BED12 columns) is now the -a side, i.e. columns 1-12.
@BEDTOOLS@ bamtobed -i sample_to_metapl.bam -bed12 -split | @BEDTOOLS@ window -w 100 -sm -a stdin -b $2 | awk '{print $1 "\t" $2 "\t" $3 "\t" $4 "\t" $5 "\t" $6 "\t" $7 "\t" $8 "\t" $9 "\t" $10 "\t" $11 "\t" $12}' | sort -k1,1 -k2,2n | @BEDTOOLS@ closest -s -t "last" -a stdin -b <(sort -k1,1 -k2,2n $2) > $3

if !  [[ -s $3 ]]; then
     echo "!!!!!   no intersections found, check input files"
     exit 1
   fi



echo "Creating metaplots..."

${libexecdir}/metag.R $3

mkdir metaplots

mv *.pdf metaplots/



echo "Done !!! "

